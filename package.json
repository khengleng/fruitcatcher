{
  "name": "fruitcatcher-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "npm --workspace apps/gateway start",
    "dev:gateway": "npm --workspace apps/gateway run dev",
    "dev:controller": "npm --workspace apps/controller-web run dev",
    "dev:admin": "npm --workspace apps/admin-web run dev",
    "dev:bot": "npm --workspace apps/bot-gateway run dev",
    "check:gateway": "node --check apps/gateway/server.js",
    "check:controller": "node --check apps/controller-web/server.js",
    "check:admin": "node --check apps/admin-web/server.js",
    "check:bot": "node --check apps/bot-gateway/server.js",
    "check": "npm run check:gateway && npm run check:controller && npm run check:admin && npm run check:bot",
    "test": "node --test tests/*.test.js"
  }
}
